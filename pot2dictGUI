def try_total_ram_gb():
    try:
        if platform.system() == "Linux":
            with open("/proc/meminfo") as f:
                for line in f:
                    if line.startswith("MemTotal:"):
                        kb = int(line.split()[1])
                        return kb / (1024 * 1024)
        elif platform.system() == "Darwin":
            out = subprocess.check_output(["sysctl", "-n", "hw.memsize"])
            return int(out.strip()) / (1024 ** 3)
        elif platform.system() == "Windows":
            import ctypes

            class MEMORYSTATUSEX(ctypes.Structure):
                _fields_ = [("dwLength", ctypes.c_ulong), ("dwMemoryLoad", ctypes.c_ulong),
                            ("ullTotalPhys", ctypes.c_ulonglong), ("ullAvailPhys", ctypes.c_ulonglong),
                            ("ullTotalPageFile", ctypes.c_ulonglong), ("ullAvailPageFile", ctypes.c_ulonglong),
                            ("ullTotalVirtual", ctypes.c_ulonglong), ("ullAvailVirtual", ctypes.c_ulonglong),
                            ("sullAvailExtendedVirtual", ctypes.c_ulonglong)]
            stat = MEMORYSTATUSEX()
            stat.dwLength = ctypes.sizeof(MEMORYSTATUSEX)
            ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(stat))
            return stat.ullTotalPhys / (1024 ** 3)
    except Exception:
        pass
    return 16.0


class Pill(tk.Label):
    """A clickable pill-style toggle used for the sort-mode picker."""
    def __init__(self, master, text, value, group, **kw):
        super().__init__(master, text=text, font=(MONO_FAMILY, 10), padx=13, pady=6,
                          bg=PANEL, fg=MUTED, cursor="hand2", **kw)
        self.value = value
        self.group = group
        self.bind("<Button-1>", lambda e: group.select(self.value))

    def set_on(self, on):
        if on:
            self.config(bg=AMBER, fg=BG, font=(MONO_FAMILY, 10, "bold"))
        else:
            self.config(bg=PANEL, fg=MUTED, font=(MONO_FAMILY, 10))


class PillGroup:
    def __init__(self, on_change):
        self.pills = []
        self.value = None
        self.on_change = on_change

    def add(self, pill):
        self.pills.append(pill)

    def select(self, value):
        self.value = value
        for p in self.pills:
            p.set_on(p.value == value)
        self.on_change()


class Switch(tk.Canvas):
    """A small on/off switch drawn on a canvas (tkinter has no native toggle)."""
    def __init__(self, master, on_change, danger=False, **kw):
        super().__init__(master, width=38, height=20, bg=PANEL, highlightthickness=0, cursor="hand2", **kw)
        self.on = False
        self.on_change = on_change
        self.danger = danger
        self.bind("<Button-1>", self.toggle)
        self.draw()

    def toggle(self, event=None):
        self.on = not self.on
        self.draw()
        self.on_change()

    def draw(self):
        self.delete("all")
        track = (AMBER_DIM if not self.danger else "#5a2a22") if self.on else LINE
        knob = (AMBER if not self.danger else RED) if self.on else DIM
        self.create_rectangle(0, 4, 38, 16, fill=track, outline="", width=0)
        x = 22 if self.on else 4
        self.create_oval(x, 2, x + 16, 18, fill=knob, outline=BG, width=2)


class Checkbox(tk.Canvas):
    """A small square checkbox drawn on a canvas — shows a clear filled
    square + checkmark when marked, and an empty outlined square when not
    marked (tk.Checkbutton's native look varies too much across platforms
    to read reliably at a glance)."""
    def __init__(self, master, on_toggle=None, checked=True, **kw):
        super().__init__(master, width=18, height=18, bg=PANEL, highlightthickness=0, cursor="hand2", **kw)
        self.checked = checked
        self.on_toggle = on_toggle
        self.bind("<Button-1>", self.toggle)
        self.draw()

    def toggle(self, event=None):
        self.checked = not self.checked
        self.draw()
        if self.on_toggle:
            self.on_toggle()

    def set_checked(self, value):
        self.checked = value
        self.draw()

    def draw(self):
        self.delete("all")
        if self.checked:
            self.create_rectangle(1, 1, 17, 17, fill=AMBER, outline=AMBER, width=1)
            # checkmark
            self.create_line(4, 9, 7.5, 13, 14, 4, fill=BG, width=2,
                              capstyle="round", joinstyle="round")
        else:
            self.create_rectangle(1, 1, 17, 17, fill=PANEL, outline=DIM, width=1)


class LabeledEntry(tk.Frame):
    def __init__(self, master, label, flag, placeholder="", on_change=None, **kw):
        super().__init__(master, bg=PANEL, **kw)
        top = tk.Frame(self, bg=PANEL)
        top.pack(fill="x", padx=14, pady=(10, 6))
        tk.Label(top, text=label, font=(MONO_FAMILY, 10), bg=PANEL, fg=MUTED).pack(side="left")
        tk.Label(top, text=flag, font=(MONO_FAMILY, 9), bg=PANEL, fg=DIM).pack(side="right")
        self.var = tk.StringVar()
        self.entry = tk.Entry(self, textvariable=self.var, font=(MONO_FAMILY, 11), bg=BG, fg=TEXT,
                               insertbackground=AMBER, relief="flat", highlightthickness=1,
                               highlightbackground=LINE, highlightcolor=AMBER_DIM)
        self.entry.pack(fill="x", padx=14, pady=(0, 12), ipady=5)
        self.placeholder = placeholder
        if on_change:
            self.var.trace_add("write", lambda *_: on_change())

    def get(self):
        return self.var.get().strip()


