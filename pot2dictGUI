        inner.pack(fill="x", padx=22, pady=12)
        dot = tk.Canvas(inner, width=10, height=10, bg=BG, highlightthickness=0)
        dot.create_oval(1, 1, 9, 9, fill=GREEN, outline="")
        dot.pack(side="left", padx=(0, 10))
        tk.Label(inner, text="pot2dict", font=(MONO_FAMILY, 14, "bold"), bg=BG, fg=TEXT).pack(side="left")
        tk.Label(inner, text=" // run console", font=(MONO_FAMILY, 14), bg=BG, fg=AMBER).pack(side="left")
        self.ramlabel = tk.Label(inner, text="", font=(MONO_FAMILY, 9), bg=BG, fg=DIM)
        self.ramlabel.pack(side="right")
        self.ramlabel.config(text=f"host RAM (detected) ≈ {self.ram_gb:.1f} GB")
