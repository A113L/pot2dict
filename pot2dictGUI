    def _section(self, parent, idx, title, desc=None):
        head = tk.Frame(parent, bg=BG)
        head.pack(fill="x", anchor="w", pady=(6, 2))
        tk.Label(head, text=idx, font=(MONO_FAMILY, 10), bg=BG, fg=AMBER_DIM).pack(side="left")
